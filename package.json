{
  "name": "mind-whisper-monorepo",
  "private": true,
  "version": "1.0.3",
  "description": "MindWhisper monorepo — macOS dictation app + marketing landing page.",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:desktop": "pnpm --filter desktop start",
