# Dependencies
node_modules/
apps/*/node_modules/

# This is a pnpm workspace — npm/yarn/bun lockfiles are never wanted
package-lock.json
apps/*/package-lock.json
yarn.lock
bun.lock

# Build output
dist/
out/
apps/desktop/dist/
apps/web/.next/
apps/web/out/

# Ignore the contents of apps/desktop/build/ (electron-builder uses it as both source and output dir)
# …except for the app icon sources, which must be tracked so CI can pick them up.
apps/desktop/build/*
!apps/desktop/build/icon.icns
!apps/desktop/build/icon.png

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json
.gstack/
