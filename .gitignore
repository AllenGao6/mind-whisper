# Dependencies
node_modules/

# Build output
dist/
out/
# Ignore the contents of build/ (electron-builder uses it as both source and output dir)
# …except for the app icon sources, which must be tracked so CI can pick them up.
build/*
!build/icon.icns
!build/icon.png

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json
