node-linker=hoisted

# Hoist EVERYTHING to the workspace-root node_modules. Without this, pnpm leaves
# many transitive deps (p-limit, find-up, locate-path, mimic-fn, semver, etc.)
# nested inside .pnpm/<pkg>/node_modules where electron-builder cannot find them.
# Result: the packaged app crashes at launch with "Cannot find module 'p-limit'"
# when electron-store → conf → pkg-up tries to resolve its sub-dependencies.
# `shamefully-hoist=true` makes pnpm's layout match npm/yarn, which is what
# electron-builder expects.
shamefully-hoist=true

# Belt-and-suspenders explicit hoist patterns (kept even though shamefully-hoist
# covers them) for visibility into what we depend on at the surface.
public-hoist-pattern[]=*electron*
public-hoist-pattern[]=*uiohook*
